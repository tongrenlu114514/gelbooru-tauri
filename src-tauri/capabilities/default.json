{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$RESOURCE/**" },
        { "path": "$APP/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$HOME/**" },
        { "path": "**" }
      ]
    }
  ]
}
